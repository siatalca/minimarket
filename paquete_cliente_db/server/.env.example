# Configuracion cliente (caja local -> BD remota)
API_HOST=127.0.0.1
PORT=3002

# Base de datos central
DB_HOST=192.168.1.91
DB_PORT=3306
DB_USER=CAMBIAR_USUARIO_DB
DB_PASSWORD=CAMBIAR_PASSWORD_DB
DB_NAME=minimarket
DB_POOL_LIMIT=10

# Seguridad
JWT_SECRET=CAMBIAR_POR_SECRETO_LARGO
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=16h

# CORS para acceso local
CORS_ORIGIN=http://localhost,http://127.0.0.1

# Correo (opcional)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=0
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# DTE (opcional)
DTE_CERT_SECRET=CAMBIAR_POR_SECRETO_DTE
