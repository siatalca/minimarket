<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <!-- Documento por defecto -->
    <defaultDocument>
      <files>
        <clear />
        <add value="index.php" />
      </files>
    </defaultDocument>

    <!-- Reglas de reescritura para proxy hacia Node -->
    <rewrite>
      <rules>
        <rule name="ProxyToNode" stopProcessing="true">
          <match url="^api/(.*)" />
          <action type="Rewrite" url="http://localhost:3002/api/{R:1}" />
        </rule>
      </rules>
    </rewrite>
    <!-- Reglas de reescritura para proxy hacia Node -->

  </system.webServer>
</configuration>
